{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/images/**", "/_next/*", "/_next/**"]
  },
  "routes": [
    {
      "route": "/artist",
      "rewrite": "/artist.html"
    },
    {
      "route": "/collection",
      "rewrite": "/collection.html"
    },
    {
      "route": "/video",
      "rewrite": "/video.html"
    },
    {
      "route": "/contact",
      "rewrite": "/contact.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=31536000, immutable",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  }
}
