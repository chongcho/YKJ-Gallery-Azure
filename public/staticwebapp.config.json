{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/_next/*"]
  },
  "routes": [
    {
      "route": "/artist",
      "rewrite": "/artist.html"
    },
    {
      "route": "/exhibition",
      "rewrite": "/exhibition.html"
    },
    {
      "route": "/collection",
      "rewrite": "/collection.html"
    },
    {
      "route": "/video",
      "rewrite": "/video.html"
    },
    {
      "route": "/contact",
      "rewrite": "/contact.html"
    },
    {
      "route": "/admin",
      "rewrite": "/admin.html"
    },
    {
      "route": "/admin/login",
      "rewrite": "/admin/login.html"
    },
    {
      "route": "/admin/paintings",
      "rewrite": "/admin/paintings.html"
    },
    {
      "route": "/admin/exhibitions",
      "rewrite": "/admin/exhibitions.html"
    },
    {
      "route": "/admin/videos",
      "rewrite": "/admin/videos.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=31536000, immutable",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  }
}
