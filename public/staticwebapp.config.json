{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/_next/*"]
  },
  "routes": [
    {
      "route": "/readyz",
      "statusCode": 404
    },
    {
      "route": "/healthz",
      "statusCode": 404
    },
    {
      "route": "/health",
      "statusCode": 404
    },
    {
      "route": "/management*",
      "statusCode": 404
    },
    {
      "route": "/manage*",
      "statusCode": 404
    },
    {
      "route": "/actuator*",
      "statusCode": 404
    },
    {
      "route": "/swagger*",
      "statusCode": 404
    },
    {
      "route": "/openapi*",
      "statusCode": 404
    },
    {
      "route": "/v3/api-docs*",
      "statusCode": 404
    },
    {
      "route": "/redoc*",
      "statusCode": 404
    },
    {
      "route": "/scalar*",
      "statusCode": 404
    },
    {
      "route": "/kubeconfig",
      "statusCode": 404
    },
    {
      "route": "/NuGet.Config",
      "statusCode": 404
    },
    {
      "route": "/applicationHost.config",
      "statusCode": 404
    },
    {
      "route": "/Properties/launchSettings.json",
      "statusCode": 404
    },
    {
      "route": "/local.settings.json",
      "statusCode": 404
    },
    {
      "route": "/docs*",
      "statusCode": 404
    },
    {
      "route": "/artist",
      "rewrite": "/artist.html"
    },
    {
      "route": "/exhibition",
      "rewrite": "/exhibition.html"
    },
    {
      "route": "/collection",
      "rewrite": "/collection.html"
    },
    {
      "route": "/video",
      "rewrite": "/video.html"
    },
    {
      "route": "/contact",
      "rewrite": "/contact.html"
    },
    {
      "route": "/admin/login",
      "rewrite": "/admin/login.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=31536000, immutable",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  }
}
